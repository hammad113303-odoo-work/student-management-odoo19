<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <data>

        <!-- ================================= -->
        <!-- Student Class List View -->
        <!-- ================================= -->

        <record id="view_student_class_list" model="ir.ui.view">

            <field name="name">student.class.list</field>

            <field name="model">student.class</field>

            <field name="arch" type="xml">

                <list>

                    <field name="name" />

                    <field name="section" />

                    <field name="teacher_id" />

                    <field name="room_no" />

                    <field name="capacity" />

                    <field name="timing" />

                    <field name="student_count" />

                    <field name="active" />

                </list>

            </field>

        </record>


        <!-- ================================= -->
        <!-- Student Class Form View -->
        <!-- ================================= -->

        <record id="view_student_class_form" model="ir.ui.view">

            <field name="name">student.class.form</field>

            <field name="model">student.class</field>

            <field name="arch" type="xml">

                <form>

                    <sheet>

                        <group>

                            <group>

                                <field name="name" />

                                <field name="section" />

                                <field name="capacity" />

                                <field name="timing" />

                            </group>

                            <group>

                                <field name="teacher_id" />

                                <field name="room_no" />

                                <field name="academic_year" />

                                <field name="active" />

                            </group>

                        </group>

                    </sheet>

                </form>

            </field>

        </record>


        <!-- ================================= -->
        <!-- Action -->
        <!-- ================================= -->

        <record id="action_student_class" model="ir.actions.act_window">

            <field name="name">Classes</field>

            <field name="res_model">student.class</field>

            <field name="view_mode">list,form</field>

        </record>


        <!-- ================================= -->
        <!-- Menus -->
        <!-- ================================= -->

        <!-- Use this only if menu_student_root does NOT already exist -->

        <!--
        <menuitem
            id="menu_student_root"
            name="Student Management"/>
        -->

        <menuitem
            id="menu_student_class"
            name="Classes"
            parent="menu_student_root"
            action="action_student_class"
            sequence="2" />

    </data>

</odoo>