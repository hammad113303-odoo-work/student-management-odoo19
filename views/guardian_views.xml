<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <data>

        <!-- ================================= -->
        <!-- Guardian List View -->
        <!-- ================================= -->

        <record id="view_student_guardian_list"
            model="ir.ui.view">

            <field name="name">student.guardian.list</field>

            <field name="model">student.guardian</field>

            <field name="arch" type="xml">

                <list>

                    <field name="guardian_id" />

                    <field name="name" />

                    <field name="relationship" />

                    <field name="phone" />

                    <field name="email" />

                    <field name="occupation" />

                    <field name="student_count" />

                    <field name="active" />

                </list>

            </field>

        </record>


        <!-- ================================= -->
        <!-- Guardian Form View -->
        <!-- ================================= -->

        <record id="view_student_guardian_form"
            model="ir.ui.view">

            <field name="name">student.guardian.form</field>

            <field name="model">student.guardian</field>

            <field name="arch" type="xml">

                <form>

                    <sheet>
                        <div class="oe_button_box" name="button_box">

                            <button
                                name="action_view_students"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-users">

                                <field
                                    name="student_count"
                                    widget="statinfo"
                                    string="Students" />

                            </button>

                        </div>

                        <group>

                            <group>

                                <field name="guardian_id" />

                                <field name="name" />

                                <field name="relationship" />

                                <field name="phone" />

                                <field name="email" />

                                <field name="cnic" />

                                <field name="occupation" />

                                <field name="active" />

                            </group>

                            <group>

                                <field name="photo"
                                    widget="image" />

                            </group>

                        </group>

                        <notebook>

                            <page string="Address">

                                <field name="address" />

                            </page>

                            <page string="Students">

                                <field name="student_ids"
                                    widget="many2many_tags" />

                            </page>

                        </notebook>

                    </sheet>

                </form>

            </field>

        </record>


        <!-- ================================= -->
        <!-- Guardian Action -->
        <!-- ================================= -->

        <record id="action_student_guardian"
            model="ir.actions.act_window">

            <field name="name">Guardians</field>

            <field name="res_model">student.guardian</field>

            <field name="view_mode">list,form</field>

        </record>


        <!-- ================================= -->
        <!-- Guardian Menu -->
        <!-- ================================= -->

        <menuitem
            id="menu_student_guardian"
            name="Guardians"
            parent="menu_student_root"
            action="action_student_guardian"
            sequence="5" />

    </data>

</odoo>