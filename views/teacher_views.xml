<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <data>

        <!-- ================================= -->
        <!-- Teacher List View -->
        <!-- ================================= -->

        <record id="view_teacher_list" model="ir.ui.view">

            <field name="name">student.teacher.list</field>

            <field name="model">student.teacher</field>

            <field name="arch" type="xml">

                <list string="Teachers">

                    <field name="teacher_id" />

                    <field name="name" />

                    <field name="phone" />

                    <field name="email" />

                    <field name="qualification" />

                    <field name="experience" />

                    <field name="joining_date" />

                    <field name="active" />

                </list>

            </field>

        </record>
        <!-- ================================= -->
        <!-- Teacher Form View -->
        <!-- ================================= -->

        <record id="view_teacher_form" model="ir.ui.view">

            <field name="name">student.teacher.form</field>

            <field name="model">student.teacher</field>

            <field name="arch" type="xml">

                <form>

                    <sheet>

                        <group>

                            <group>

                                <field name="teacher_id" readonly="1" />

                                <field name="name" />

                                <field name="phone" />

                                <field name="email" />

                            </group>

                            <group>

                                <field name="qualification" />

                                <field name="experience" />

                                <field name="joining_date" />

                                <field name="active" />

                            </group>

                        </group>

                        <group>

                            <field name="photo"
                                widget="image"
                                class="oe_avatar" />

                        </group>

                    </sheet>

                </form>

            </field>

        </record>
        <!-- ================================= -->
        <!-- Teacher Action -->
        <!-- ================================= -->

        <record id="action_teacher" model="ir.actions.act_window">

            <field name="name">Teachers</field>

            <field name="res_model">student.teacher</field>

            <field name="view_mode">list,form</field>

        </record>
        <!-- ================================= -->
        <!-- Teacher Menu -->
        <!-- ================================= -->

        <menuitem
            id="menu_teacher"
            name="Teachers"
            parent="menu_student_root"
            action="action_teacher"
            sequence="3" />

    </data>

</odoo>